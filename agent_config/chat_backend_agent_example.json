{
  "name": "platform_test_2",
  "system_prompt": "You are a helpful phone assistant. Keep responses concise and natural for a voice call.",
  "llm": {
    "provider": "openai",
    "model": "existing-chat-agent",
    "kwargs": {
      "base_url": "http://127.0.0.1:9000/v1",
      "api_key": "dev-key"
    }
  },
  "stt": {
    "provider": "deepgram",
    "model": "nova-3",
    "kwargs": {
      "language": "en-IN",
      "detect_language": false,
      "interim_results": true
    }
  },
  "tts": {
    "model": "eleven_flash_v2_5",
    "kwargs": {
      "voice_id": "w2CTE3MYza6FgBnETYNT"
    },
    "provider": "elevenlabs"
  },
  "vad": {
    "provider": "silero",
    "kwargs": {
      "min_speech_duration": 0.07,
      "min_silence_duration": 0.7,
      "activation_threshold": 0.5,
      "force_cpu": true,
      "sample_rate": 16000
    }
  },
  "tools": [
    "livekit_agents_tools.session_tools.end_call",
    "livekit_agents_tools.session_tools.transfer_call"
  ],
  "worker": {
    "agent_name": "platform_test_2",
    "job_memory_warn_mb": 2000,
    "shutdown_process_timeout": 80.0,
    "initialize_process_timeout": 540,
    "num_idle_processes": 1,
    "port": 8082
  },
  "session": {
    "enable_telephony_noise_cancellation": false,
    "noise_cancellation_provider": "bvc_telephony",
    "noise_cancellation_kwargs": {},
    "kwargs": {},
    "transfer_phone_number": "+14155550123"
  }
}
