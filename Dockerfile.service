FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    STREAMLIT_SERVER_PORT=8501 \
    STREAMLIT_SERVER_ADDRESS=0.0.0.0

WORKDIR /app

RUN apt-get update && apt-get install -y curl && \
    curl -fsSL -o /usr/local/bin/kubectl https://dl.k8s.io/release/v1.33.7/bin/linux/amd64/kubectl && \
    chmod +x /usr/local/bin/kubectl && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.txt ./
COPY agent_config ./agent_config
COPY livekit_agents ./livekit_agents
COPY livekit_agents_tools ./livekit_agents_tools
COPY livekit_trunks ./livekit_trunks
COPY scripts ./scripts
COPY backend_service.py streamlit_app.py main.py ./

RUN pip install --upgrade pip && pip install .

EXPOSE 8501

CMD ["streamlit", "run", "streamlit_app.py", "--server.port=8501", "--server.address=0.0.0.0"]
