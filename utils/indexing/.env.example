# -----------------------------
# Core collection scope
# -----------------------------
COLLECTION_ID=
ORG_ID=

# -----------------------------
# Azure OpenAI - LLM
# -----------------------------
LLM_AZURE_OPENAI_API_KEY=
LLM_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
LLM_AZURE_OPENAI_API_VERSION=2024-02-01
LLM_AZURE_OPENAI_MODEL=gpt-4o
LLM_AZURE_OPENAI_DEPLOYMENT_NAME=
LLM_AZURE_OPENAI_DEPLOYMENT=

# -----------------------------
# Azure OpenAI - Embeddings
# -----------------------------
AZURE_OPENAI_EMBEDDING_MODEL_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_EMBEDDING_MODEL_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_MODEL_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIM=1536

# -----------------------------
# PgVector / Postgres
# -----------------------------
PGVECTOR_DATABASE_URL=
DATABASE_URL=
PGVECTOR_SCHEMA=public
PGVECTOR_TABLE_PREFIX=vva_
PGVECTOR_EXTENSIONS_SCHEMA=extensions
PGVECTOR_POOL_SIZE=1
PGVECTOR_MAX_OVERFLOW=0
PGVECTOR_POOL_RECYCLE=300
IVFPROBES=10

# -----------------------------
# Ingestion / indexing
# -----------------------------
PGVECTOR_INGEST_WORKERS=6
KB_SHARD_MAX_SIZE=200
INDEXING_MAX_RETRIES=5
INDEXING_RETRY_DELAY_SECONDS=2
MAX_KB_DOCS=250
ALLOW_FULL_KB_PURGE=false

# -----------------------------
# Retrieval - base search
# -----------------------------
PGVECTOR_KB_TOP_K=8
KB_TOP_K=8
PGVECTOR_KB_OVERSAMPLE_MULT=6
PGVECTOR_CATEGORY_BOOST_OVERSAMPLE_MULT=2
PGVECTOR_VECTOR_CATEGORY_MATCH_MULT=0.85
PGVECTOR_VECTOR_CATEGORY_BOTH_MULT=0.90
PGVECTOR_VECTOR_CATEGORY_OTHER_MULT=1.00
PGVECTOR_FTS_CATEGORY_MATCH_MULT=1.15
PGVECTOR_FTS_CATEGORY_BOTH_MULT=1.10
PGVECTOR_FTS_CATEGORY_OTHER_MULT=1.00
PGVECTOR_VECTOR_WEIGHT=0.45
PGVECTOR_FTS_KEYWORDS_WEIGHT=0.25
PGVECTOR_FTS_SUMMARIES_WEIGHT=0.30
PGVECTOR_RRF_K=60
PGVECTOR_SEARCH_PHRASE_TOPK_MULT=2
PGVECTOR_ACRONYM_TOPK_MULT=2
PGVECTOR_PER_SHARD_TOP_K=25
PGVECTOR_RETRIEVAL_TOP_K=50
PGVECTOR_CONTENT_SNIPPET_CHARS=1800

# -----------------------------
# Reranking
# -----------------------------
PGVECTOR_RERANK_TOP_N=5
PGVECTOR_RERANK_STRATEGY=ce
PGVECTOR_USE_CE_RERANK=1
PGVECTOR_CE_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
PGVECTOR_CE_BATCH_SIZE=16
PGVECTOR_CE_TIE_DEDUP_ENABLED=1
PGVECTOR_CE_TIE_MARGIN=0.08
PGVECTOR_CE_TIE_TOPK=2
PGVECTOR_CE_INTRA_FAMILY_CE=1
PGVECTOR_USE_LLM_RERANK=0
PGVECTOR_LLM_RERANK_MODEL=gpt-4o-mini
PGVECTOR_LLM_GROUP_SIZE=5
PGVECTOR_LLM_RERANK_TIMEOUT=15.0
PGVECTOR_LLM_SMALL_POOL_THRESHOLD=10
PGVECTOR_CONTENT_SNIPPET_IN_PROMPT=400
KB_TOP2_VS_REST_RATIO=1.5
KB_KEEP_SCORE_RATIO=0.8
KB_MIN_CANDIDATES=2
KB_MAX_CANDIDATES=10
PGVECTOR_DEBUG_RERANK=1
PGVECTOR_DEBUG_RERANK_TOPM=10

# -----------------------------
# OpenAI retry / throttling
# -----------------------------
OPENAI_MAX_RETRIES=6
OPENAI_BACKOFF_INITIAL=1.0
OPENAI_BACKOFF_MAX=60.0
OPENAI_BACKOFF_MULTIPLIER=2.0
OPENAI_BACKOFF_JITTER=0.25
OPENAI_RETRY_BASE_SECONDS=1.0
OPENAI_RETRY_MAX_SECONDS=30.0
OPENAI_RETRY_JITTER=0.25
KB_VALIDATION_THROTTLE_SECONDS=0.0
