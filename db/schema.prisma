datasource db {
  provider = "postgresql"
}

model voice_virtual_agent_call_status {
  created_at   DateTime                   @default(now()) @db.Timestamptz(6)
  call_id      String?                    @db.Uuid
  content_type String?                    @db.VarChar
  role         String?                    @db.VarChar
  content      Json?                      @db.Json
  id           String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kb_used      String?                    @db.VarChar
  call         voice_virtual_agent_calls? @relation(fields: [call_id], references: [id])

  @@index([call_id, created_at])
}

model voice_virtual_agent_calls {
  id                              String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                      DateTime                          @default(now()) @db.Timestamptz(6)
  caller                          String?
  ended_reason                    String?
  details_url                     String?
  ticket_id                       String?
  ended_at                        DateTime?                         @db.Timestamptz(6)
  recordingUrl                    String?                           @db.VarChar
  status                          String?                           @db.VarChar
  user_name                       String?                           @db.VarChar
  user_sys_id                     String?                           @db.VarChar
  called_at                       String?
  voice_virtual_agent_id          String?                           @db.Uuid
  incident_ticket_ids             String[]                          @default([])
  interaction_id                  String?
  summary                         String?                           @db.VarChar
  sentiment                       String?                           @db.VarChar
  queries                         String?                           @db.VarChar
  reported_issue                  String?                           @db.VarChar
  voice_virtual_agent_call_status voice_virtual_agent_call_status[]
  voice_virtual_agent             voice_virtual_agents?             @relation(fields: [voice_virtual_agent_id], references: [id])
}

model voice_virtual_agents {
  id                        String                             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                DateTime                           @default(now()) @db.Timestamptz(6)
  org_id                    String?                            @db.Uuid
  phone_number              String                             @unique @db.VarChar
  config                    Json?                              @db.Json
  name                      String?                            @unique @db.VarChar
  kb_id                     String?                            @db.Uuid
  agent_type                String?
  agent_id                  String?                            @db.Uuid
  agent_prompt              Json?                              @db.Json
  voice_virtual_agent_calls voice_virtual_agent_calls[]
  deployments               voice_virtual_agent_deployments[]
  sip_bindings              voice_virtual_agent_sip_bindings[]
}

model voice_virtual_agent_deployments {
  id                     String                                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at             DateTime                                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                                @updatedAt @db.Timestamptz(6)
  voice_virtual_agent_id String                                  @db.Uuid
  agent_name             String                                  @db.VarChar
  agent_type             String?                                 @db.VarChar
  agent_version          String                                  @db.VarChar
  namespace              String                                  @db.VarChar
  deployment_name        String                                  @db.VarChar
  service_name           String?                                 @db.VarChar
  image                  String?                                 @db.VarChar
  image_tag              String?                                 @db.VarChar
  desired_state          String                                  @db.VarChar
  workflow_status        String                                  @db.VarChar
  runtime_status         String?                                 @db.VarChar
  health_status          String?                                 @db.VarChar
  generation             Int?
  observed_generation    Int?
  desired_replicas       Int                                     @default(1)
  ready_replicas         Int                                     @default(0)
  available_replicas     Int                                     @default(0)
  restart_count          Int                                     @default(0)
  requested_by           String?                                 @db.VarChar
  request_id             String?                                 @unique @db.Uuid
  last_error             String?
  last_error_at          DateTime?                               @db.Timestamptz(6)
  last_observed_at       DateTime?                               @db.Timestamptz(6)
  deployed_at            DateTime?                               @db.Timestamptz(6)
  ready_at               DateTime?                               @db.Timestamptz(6)
  deleted_at             DateTime?                               @db.Timestamptz(6)
  status_reason          String?                                 @db.VarChar
  status_details         Json?                                   @db.Json
  events                 voice_virtual_agent_deployment_events[]
  voice_virtual_agent    voice_virtual_agents                    @relation(fields: [voice_virtual_agent_id], references: [id])

  @@index([voice_virtual_agent_id, created_at])
  @@index([agent_name, created_at])
  @@index([workflow_status, updated_at])
  @@index([runtime_status, updated_at])
  @@index([namespace, deployment_name])
}

model voice_virtual_agent_deployment_events {
  id              String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime                        @default(now()) @db.Timestamptz(6)
  deployment_id   String                          @db.Uuid
  event_type      String                          @db.VarChar
  workflow_status String?                         @db.VarChar
  runtime_status  String?                         @db.VarChar
  health_status   String?                         @db.VarChar
  message         String?
  payload         Json?                           @db.Json
  deployment      voice_virtual_agent_deployments @relation(fields: [deployment_id], references: [id])

  @@index([deployment_id, created_at])
  @@index([event_type, created_at])
}

model voice_virtual_agent_sip_bindings {
  id                     String                                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at             DateTime                                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                                 @updatedAt @db.Timestamptz(6)
  voice_virtual_agent_id String                                   @db.Uuid
  provider               String                                   @default("livekit") @db.VarChar
  agent_name             String                                   @unique @db.VarChar
  agent_version          String?                                  @db.VarChar
  phone_number           String                                   @unique @db.VarChar
  trunk_id               String?                                  @unique @db.VarChar
  trunk_name             String?                                  @db.VarChar
  dispatch_rule_id       String?                                  @unique @db.VarChar
  dispatch_rule_name     String?                                  @db.VarChar
  room_prefix            String?                                  @db.VarChar
  desired_state          String                                   @db.VarChar
  workflow_status        String                                   @db.VarChar
  health_status          String?                                  @db.VarChar
  is_active              Boolean                                  @default(true)
  last_checked_at        DateTime?                                @db.Timestamptz(6)
  provisioned_at         DateTime?                                @db.Timestamptz(6)
  last_error             String?
  last_error_at          DateTime?                                @db.Timestamptz(6)
  status_reason          String?                                  @db.VarChar
  status_details         Json?                                    @db.Json
  events                 voice_virtual_agent_sip_binding_events[]
  voice_virtual_agent    voice_virtual_agents                     @relation(fields: [voice_virtual_agent_id], references: [id])

  @@index([voice_virtual_agent_id, created_at])
  @@index([workflow_status, updated_at])
  @@index([health_status, updated_at])
  @@index([is_active, updated_at])
}

model voice_virtual_agent_sip_binding_events {
  id              String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime                         @default(now()) @db.Timestamptz(6)
  sip_binding_id  String                           @db.Uuid
  event_type      String                           @db.VarChar
  workflow_status String?                          @db.VarChar
  health_status   String?                          @db.VarChar
  message         String?
  payload         Json?                            @db.Json
  sip_binding     voice_virtual_agent_sip_bindings @relation(fields: [sip_binding_id], references: [id])

  @@index([sip_binding_id, created_at])
  @@index([event_type, created_at])
}
