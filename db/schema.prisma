// ----------------------------------------- TAGS & COLLECTION TAGS ----------------------------------

model tags {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar
  description String?  @db.VarChar
  org_id      String   @db.Uuid
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  org                           organizations                   @relation(fields: [org_id], references: [id])
  collections                   knowledgebase_collection_tags[]
  tag_leads                     tag_lead[]
  knowledgebase_collection_user knowledgebase_collection_user[]

  @@unique([org_id, name])
  @@index([is_deleted])
}

model knowledgebase_collection_tags {
  collection_id String   @db.Uuid
  tag_id        String   @db.Uuid
  org_id        String   @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  collection knowledgebase_collection @relation(fields: [collection_id], references: [id])
  tag        tags                     @relation(fields: [tag_id], references: [id])
  org        organizations            @relation(fields: [org_id], references: [id])

  @@id([collection_id, tag_id])
  @@index([tag_id])
}

model tag_lead {
  id      Int    @id @default(autoincrement())
  tag_id  String @db.Uuid
  user_id String @db.Uuid
  org_id  String @db.Uuid

  created_at     DateTime @default(now()) @db.Timestamptz(6)
  assigned_by_id String   @db.Uuid

  tag         tags          @relation(fields: [tag_id], references: [id], onDelete: Cascade)
  user        users         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org         organizations @relation(fields: [org_id], references: [id], onDelete: Cascade)
  assigned_by users         @relation(fields: [assigned_by_id], references: [id], name: "assigned_by")

  @@index([org_id])
  @@index([user_id])
  @@index([tag_id])
}

model knowledgebase_collection_user {
  id             Int    @id @default(autoincrement())
  collection_id  String @db.Uuid
  user_id        String @db.Uuid
  org_id         String @db.Uuid
  assigned_by_id String @db.Uuid

  created_at DateTime @default(now()) @db.Timestamptz(6)

  collection  knowledgebase_collection @relation(fields: [collection_id], references: [id])
  user        users                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org         organizations            @relation(fields: [org_id], references: [id], onDelete: Cascade)
  assigned_by users                    @relation(fields: [assigned_by_id], references: [id], name: "assigned_by")
  tags        tags?                    @relation(fields: [tagsId], references: [id])
  tagsId      String?                  @db.Uuid

  @@index([org_id])
  @@index([user_id])
  @@index([collection_id])
}

model AppRole {
  id    Int    @id @default(autoincrement())
  orgId String @db.Uuid

  // The external group's unique identifier (e.g., ServiceNow sys_id)
  relatedRecordId   String
  // The external group's human-readable name
  relatedRecordName String
  // The source system of the external group
  relatedRecordType String

  // This AppRole can be used as the source in one or more mapping rules.
  mappingRules RoleMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // An external group should only be registered once per org.
  @@unique([orgId, relatedRecordType, relatedRecordId])
}

// 2. THE INTERNAL ROLES: Defines the roles your application code uses.
model RoleDefinition {
  id Int @id @default(autoincrement())

  orgId       String? @db.Uuid // Nullable for global roles
  // The internal name your app checks against, e.g., "module-a-user"
  name        String
  description String?

  // This role can be the destination of one or more mapping rules.
  mappingRules RoleMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // This role can be assigned to multiple users.
  assignedToUsers UserAssignedRole[]

  @@unique([orgId, name])
}

model RoleMapping {
  id    Int    @id @default(autoincrement())
  orgId String @db.Uuid

  // The source of the rule (which external group?)
  appRoleId Int
  appRole   AppRole @relation(fields: [appRoleId], references: [id])

  // The destination of the rule (what internal role does it grant?)
  roleDefinitionId Int
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // A given external group should only be mapped to a given internal role once.
  @@unique([appRoleId, roleDefinitionId])
}

model UserAssignedRole {
  userId           String         @db.Uuid
  user             users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleDefinitionId Int
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id], onDelete: Cascade)

  assignmentType AssignmentType @default(AUTOMATIC)

  assignedAt DateTime @default(now())

  @@id([userId, roleDefinitionId])
}

enum AssignmentType {
  AUTOMATIC // Assigned via an external group mapping (Okta/ServiceNow)
  MANUAL // Assigned manually by an admin in your app (the override)
}

model user_onboarding {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String           @unique @db.VarChar
  full_name String           @db.VarChar
  org_id    String?          @db.Uuid
  comment   String?          @db.Text
  status    OnboardingStatus @default(pending_verification)
  partner   String           @db.VarChar

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  organization organizations? @relation(fields: [org_id], references: [id])

  @@index([status])
  @@index([org_id])
  @@index([created_at])
  @@index([email])
}

model ticket_virtual_agent_dashboard {
  id               String       @id @db.VarChar // Assuming ServiceNow ticket IDs are strings
  org_id           String       @db.Uuid
  assignment_group String?      @db.VarChar
  status           TicketStatus @default(IN_PROGRESS)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime     @default(now()) @db.Timestamptz(6)

  // New fields
  conversation_history String?  @db.VarChar
  kbs_referenced       String[] @db.VarChar
  emails_sent          Int?
}

enum TicketStatus {
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
  ESCALATED
}

enum HandoverStatus {
  NOT_STARTED
  STARTED
  DONE
}

model knowledgebase_styles {
  id           Int      @id @default(autoincrement())
  org_id       String   @unique @db.Uuid
  style_config Json     @db.Json
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  org organizations @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@index([org_id])
}

model knowledgebase_templates {
  id               Int      @id @default(autoincrement())
  org_id           String   @db.Uuid
  name             String   @db.VarChar
  description      String?  @db.Text
  template_content String   @db.Text
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  org organizations @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@unique([org_id, name])
  @@index([org_id])
}

// ----------------------------------------- DAILY APPROVALS SUMMARY TRACKING ----------------------------------

model daily_approvals_summary_log {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id    String   @db.Uuid
  user_id   String   @db.Uuid
  upn       String   @db.VarChar
  user_name String?  @db.VarChar
  sent_at   DateTime @default(now()) @db.Timestamptz(6)

  // Notification status
  status      DailySummaryNotificationStatus
  skip_reason String?                        @db.VarChar
  error_msg   String?                        @db.Text

  // User's pending items snapshot
  pending_approvals        Int @default(0)
  pending_service_requests Int @default(0)

  // Tracking
  user_timezone        String?   @db.VarChar
  last_notification_at DateTime? @db.Timestamptz(6)

  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  organization organizations @relation(fields: [org_id], references: [id])
  user         users         @relation(fields: [user_id], references: [id])

  @@index([org_id, sent_at])
  @@index([user_id, sent_at])
  @@index([upn, sent_at])
  @@index([status])
  @@index([sent_at])
}

model employee_id_mapping {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cg_emp_id  String   @unique @db.VarChar
  cg_name    String?  @db.VarChar
  cg_email   String?  @db.VarChar
  gd_emp_id  String?  @db.VarChar
  gd_name    String?  @db.VarChar
  gd_email   String?  @db.VarChar
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([cg_emp_id])
  @@index([gd_emp_id])
  @@index([cg_email])
  @@index([gd_email])
}

model coresolve_active_user_connections {
  user_id         String   @db.Text
  websocket_id    String   @db.Text
  connection_info Json     @db.JsonB
  namespace       String   @default("") @db.Text
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  @@id([namespace, user_id, websocket_id])
  @@index([namespace, user_id, updated_at(sort: Desc)], name: "idx_user_connections_lookup")
  @@map("coresolve_active_user_connections")
}

model coresolve_active_meeting_connections {
  meeting_id      String   @db.Text
  websocket_id    String   @db.Text
  connection_info Json     @db.JsonB
  namespace       String   @default("") @db.Text
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  @@id([namespace, meeting_id, websocket_id])
  @@index([namespace, meeting_id, updated_at(sort: Desc)], name: "idx_meeting_connections_lookup")
  @@map("coresolve_active_meeting_connections")
}