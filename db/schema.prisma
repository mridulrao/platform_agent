// -------------------- Bot Interaction Logging & Feedback Schemas START --------------------

// Enum for Interaction Outcome
// Describes the final result or state of a single interaction turn (user query -> bot response).
enum InteractionOutcome {
  STARTED // Initial state before response is logged
  COMPLETED_OK // Bot provided a response, no explicit error or negative feedback yet
  TICKET_CREATED // A ServiceNow Incident/Request was successfully created
  TICKET_UPDATED // A ServiceNow Incident/Request was successfully updated
  ACCOUNT_UNLOCKED // Account unlock skill succeeded
  FEEDBACK_PROVIDED_POSITIVE // User provided positive feedback for this interaction (Outcome can be updated post-response)
  FEEDBACK_PROVIDED_NEGATIVE // User provided negative feedback for this interaction (Outcome can be updated post-response)
  ERROR_BOT // An error occurred within the bot framework/handlers
  ERROR_BACKEND // An error occurred calling the backend API
  ERROR_SERVICE // An error occurred calling an external service (SNOW, Intune)
  NO_ANSWER_FOUND // Bot explicitly determined it couldn't answer
  ESCALATED // Interaction was escalated to a human agent
  CLARIFICATION_NEEDED // Bot asked a clarifying question
  CANCELLED // User cancelled the action (e.g., task module)
}

// Enum for Service Delivery Action
// Categorizes the type of IT service delivery action the bot performed or attempted.
enum ServiceAction {
  PROVISION // e.g., Creating account, granting access
  TROUBLESHOOT // e.g., Diagnosing an issue, looking up errors
  MANAGE // e.g., Updating ticket, modifying group membership
  INFORM // e.g., Providing KB info, checking status, password expiry
  REQUEST // e.g., Initiating a catalog request
  UNLOCK // e.g., Account unlock action
  OTHER // Any action not covered by the above
}

// Enum for User Feedback Rating
// Represents the simple binary feedback provided by the user.
enum FeedbackRating {
  POSITIVE
  NEGATIVE
}

// Central model for logging each interaction turn (user query -> bot response).
// This table provides the detailed data for analytics and feedback correlation.
model Interaction {
  // Core Fields
  id              String @id @default(uuid())
  conversation_id String
  session_id      String
  user_aad_id     String
  org_id          String

  // Timestamps
  timestamp_query    DateTime
  timestamp_response DateTime?

  // Query & Response Content
  user_query_text      String  @db.Text
  bot_response_content String? @db.Text
  response_type        String?
  card_type            String?

  // Analysis & Classification Fields
  intent_topic       String?
  skill_tag          String?
  service_action     ServiceAction?
  citations_provided Boolean        @default(false)
  ticket_system_ref  String?

  // Outcome & Error Tracking
  interaction_outcome InteractionOutcome @default(STARTED)
  error_occurred      Boolean            @default(false)
  error_message       String?            @db.Text
  error_type          String?
  error_component     String?

  // AI Evaluation Tracking
  ai_evaluated Boolean @default(false)

  // Timestamps & Relations
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userFeedbacks UserFeedback[]
  aiFeedbacks   AIFeedback[]

  // Indexes for Query Performance
  @@index([conversation_id])
  @@index([session_id])
  @@index([user_aad_id])
  @@index([org_id])
  @@index([intent_topic])
  @@index([skill_tag])
  @@index([interaction_outcome])
  @@index([error_occurred])
  @@index([ai_evaluated])
  @@index([timestamp_query])
}

// Model for storing user-submitted feedback (e.g., Thumbs Up/Down).
model UserFeedback {
  id                 String         @id @default(uuid())
  interactionId      String
  user_aad_id        String
  timestamp_feedback DateTime       @default(now())
  rating             FeedbackRating
  comment            String?        @db.Text

  // Timestamps & Relation
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  interaction Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  // Index for querying feedback by interaction
  @@index([user_aad_id])
  @@index([interactionId])
}

// Model for storing AI evaluation feedback (Future Use / Optional Component).
// Stores the results from an automated AI assessment of the interaction quality.
model AIFeedback {
  id                      String   @id @default(uuid())
  interactionId           String   @unique
  ai_evaluator_model      String
  ai_evaluation_timestamp DateTime @default(now())

  // Example AI Evaluation Scores 
  ai_score_relevance    Float?
  ai_score_helpfulness  Float?
  ai_score_groundedness Float?
  ai_score_safety       Float?

  // AI Critique & Flags
  ai_critique_summary String?  @db.Text
  ai_flags            String[]

  // Timestamps & Relation
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  interaction Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
}

// New Enums for V2 Simulation Feature
enum SimulationDifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum SimulationActivityStatus {
  IN_PROGRESS
  COMPLETED_PASS
  COMPLETED_FAIL_TIME
  COMPLETED_FAIL_STEPS
  ABORTED
}

// New Models for V2 Simulation Feature
model SimulationTheme {
  id                                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  train_assist_topic_id             String                    @db.Uuid // FK to TrainAssistTopic.id
  learning_topic_title              String                    @db.VarChar // Title of the sub-topic within the TrainAssistTopic
  title                             String                    @db.VarChar // Short title of the simulation theme itself
  customer_problem_statement        String                    @db.Text
  keywords                          String[]
  difficulty                        SimulationDifficultyLevel
  time_limit_seconds                Int
  expected_resolution_steps_summary String                    @db.Text
  is_active                         Boolean                   @default(false)
  org_id                            String                    @db.Uuid
  collection_id                     String?                   @db.Uuid
  created_at                        DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime                  @updatedAt @db.Timestamptz(6)

  train_assist_topic train_assist_topics       @relation(fields: [train_assist_topic_id], references: [id], onDelete: Cascade)
  organization       organizations             @relation(fields: [org_id], references: [id], onDelete: Cascade)
  collection         knowledgebase_collection? @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  activities         SimulationActivity[]

  @@index([train_assist_topic_id])
  @@index([org_id])
  @@index([collection_id])
  @@index([is_active])
}

model SimulationActivity {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String?                  @db.Uuid
  theme_id                String                   @db.Uuid
  simulation_session_id   String                   @unique // External ID for the active session attempt
  status                  SimulationActivityStatus @default(IN_PROGRESS)
  score                   Int?
  time_taken_seconds      Int?
  conversation_log        Json?
  evaluation_feedback     String?                  @db.Text
  evaluation_details_json Json?
  org_id                  String                   @db.Uuid
  started_at              DateTime                 @default(now()) @db.Timestamptz(6)
  completed_at            DateTime?                @db.Timestamptz(6)

  user         users?          @relation(fields: [user_id], references: [id], onDelete: SetNull)
  theme        SimulationTheme @relation(fields: [theme_id], references: [id], onDelete: Cascade)
  organization organizations   @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([theme_id])
  @@index([org_id])
  @@index([status])
}

//---------------------------------------- MEETING JOINER START ----------------------------------------
model meeting_joiner {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meeting_url    String                @db.VarChar
  status         meeting_joiner_status @default(not_joined)
  video_link     String?               @db.VarChar
  transcript     Json?                 @db.Json
  participants   Json?                 @db.Json
  org_id         String?               @db.Uuid
  meeting_id     String?               @db.Uuid
  bot_join_time  DateTime?             @db.Timestamptz(6)
  bot_leave_time DateTime?             @db.Timestamptz(6)
  bot_name       String?               @db.VarChar(100)
  process_id     Int?
  created_at     DateTime              @default(now()) @db.Timestamptz(6)
  updated_at     DateTime              @default(now()) @db.Timestamptz(6)

  org     organizations? @relation(fields: [org_id], references: [id])
  meeting meetings?      @relation(fields: [meeting_id], references: [meeting_id])

  @@index([status])
  @@index([org_id])
  @@index([created_at])
  @@index([process_id])
}

